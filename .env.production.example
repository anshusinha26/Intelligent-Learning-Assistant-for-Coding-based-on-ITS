APP_ENV=production
HOST=0.0.0.0
PORT=8000
DB_PATH=/app/data/coding_assistant.db
SECRET_KEY=replace-with-64-char-random-secret
DEV_EXPOSE_OTP=false
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SYMBOL=true
HSTS_ENABLED=true
ALLOW_PUBLIC_BIND=true
METRICS_ENABLED=true
CORS_ALLOW_ORIGINS=https://your-frontend-domain.example
RAG_ENABLED=true
RAG_MODE=local
RAG_ALLOW_FULL_SOLUTIONS=false
RAG_ENFORCE_HINT_PROGRESSION=true
RAG_THREAD_STATE_MAX=5000
